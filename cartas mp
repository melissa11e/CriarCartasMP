def mostrar_tooltip(event):

    global tooltip

    tooltip = tk.Toplevel(root)

    tooltip.wm_overrideredirect(True)

    x = event.widget.winfo_rootx() + 40

    y = event.widget.winfo_rooty() + 20

    tooltip.wm_geometry(f"+{x}+{y}")

    texto = (
        "As variáveis na planilha Excel precisam\n"
        "estar com os nomes da seguinte maneira:\n\n"
        "(Cuidado com espaço e Caps Lock)\n\n"
        "ID\n"
        "NOME\n"
        "NOME CURTO\n"
        "CARGO NOVO\n"
        "SALARIO NOVO\n"
        "FLEX NOVO"
        "GERENTE"
    )

    label = tk.Label(
        tooltip,
        text=texto,
        justify="left",
        bg="#FFA726",
        fg="black",
        relief="solid",
        bd=1,
        padx=12,
        pady=10,
        font=("Arial", 9)
    )

    label.pack()

def esconder_tooltip(event):

    global tooltip

    if tooltip:

        tooltip.destroy()

        tooltip = None

