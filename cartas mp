# =====================================
# QUEBRAR LINHAS
# =====================================

def quebrar_linhas(draw, texto, fonte, largura_maxima):

    palavras = texto.split()

    linhas = []

    linha_atual = ""

    for palavra in palavras:

        if linha_atual == "":
            teste = palavra
        else:
            teste = linha_atual + " " + palavra

        bbox = draw.textbbox(
            (0, 0),
            teste,
            font=fonte
        )

        largura = bbox[2] - bbox[0]

        if largura <= largura_maxima:

            linha_atual = teste

        else:

            linhas.append(linha_atual)

            linha_atual = palavra

    if linha_atual:

        linhas.append(linha_atual)

    return linhas

# =====================================
# TEXTO VARIÁVEL
# =====================================

def gerar_texto_variavel(
    cargo,
    salario,
    beneficio,
    MES_ANO
):

    partes = []

    if cargo:

        partes.append(
            f"novo cargo de {cargo}"
        )

    if salario:

        partes.append(
            f"salário de R${salario}"
        )

    if beneficio:

        partes.append(
            f"benefício flexível de R${beneficio}"
        )

    if len(partes) == 0:

        return ""

    texto_final_singular = (
        f", que será considerado "
        f"a partir de {MES_ANO}."
    )

    texto_final_plural = (
        f", que serão considerados "
        f"a partir de {MES_ANO}."  
    )

    # =================================
    # UMA INFORMAÇÃO
    # =================================

    if len(partes) == 1:

        return (
            "Estamos felizes de compartilhar "
            f"seu {partes[0]}"
            f"{texto_final_singular}"
        )

    # =================================
    # DUAS INFORMAÇÕES
    # =================================

    elif len(partes) == 2:

        return (
            "Estamos felizes de compartilhar "
            f"seu {partes[0]} e "
            f"{partes[1]}"
            f"{texto_final_plural}"
        )

    # =================================
    # TRÊS INFORMAÇÕES
    # =================================

    else:

        return (
            "Estamos felizes de compartilhar "
            f"seu {partes[0]}, "
            f"{partes[1]} e "
            f"{partes[2]}"
            f"{texto_final_plural}"
        )

# =====================================
# GERAR CARTAS
# =====================================

def gerar_cartas():

    PLANILHA = entrada_planilha.get()

    PASTA_SAIDA = entrada_pasta.get()

    mes = combo_mes.get()

    ano = combo_ano.get()

    # =================================
    # VALIDAÇÕES
    # =================================

    if not PLANILHA:

        messagebox.showerror(
            "Erro",
            "Selecione a planilha."
        )

        return

    if not PASTA_SAIDA:

        messagebox.showerror(
            "Erro",
            "Selecione a pasta."
        )

        return

    if not mes or not ano:

        messagebox.showerror(
            "Erro",
            "Selecione mês e ano."
        )

        return

    # =================================
    # MÊS/ANO
    # =================================

    MES_ANO = f"{mes}/{ano}"

    # =================================
    # CRIAR PASTA
    # =================================

    os.makedirs(
        PASTA_SAIDA,
        exist_ok=True
    )

    # =================================
    # LER PLANILHA
    # =================================

    df = pd.read_excel(PLANILHA)

    # =================================
    # FONTES
    # =================================

    fonte_nome = ImageFont.truetype(
        FONTE_NOME,
        TAMANHO_NOME
    )

    fonte_texto = ImageFont.truetype(
        FONTE_TEXTO,
        TAMANHO_TEXTO
    )

    # =================================
    # LOOP
    # =================================

    for _, row in df.iterrows():

        imagem = Image.open(
            IMAGEM_BASE
        ).convert("RGB")

        draw = ImageDraw.Draw(imagem)

        # =============================
        # DADOS
        # =============================

        nome = str(
            row["NOME CURTO"]
        ).strip()

        cargo = str(
            row["CARGO NOVO"]
        ).strip()

        salario = str(
            row["SALARIO NOVO"]
        ).strip()

        beneficio = str(
            row["FLEX NOVO"]
        ).strip()

        gerente = str(
            row["GERENTE"]
        ).strip()

        # =============================
        # REMOVER NAN
        # =============================

        nome = (
            ""
            if nome.lower() == "nan"
            else nome
        )

        cargo = (
            ""
            if cargo.lower() == "nan"
            else cargo
        )

        salario = (
            ""
            if salario.lower() == "nan"
            else salario
        )

        beneficio = (
            ""
            if beneficio.lower() == "nan"
            else beneficio
        )

        gerente = (
            ""
            if gerente.lower() == "nan"
            else gerente
        )



        # =============================
        # TEXTOS
        # =============================

        texto_intro = (
            "Aqui na Hitss Brasil, "
            "brilha quem se dedica, "
            "entrega, tem atitude "
            "e a cultura na veia."
        )

        texto_variavel = gerar_texto_variavel(
            cargo,
            salario,
            beneficio,
            MES_ANO
        )

        texto_gerente = ""
        if gerente:
            texto_gerente = "Com esta mudança, não será mais necessário" \
            " o lançamento de horas no Sistema de Controle de Ponto " \
            "Orhganiza. Essa alteração foi aprovada pela gestão e " \
            "está em conformidade com as políticas internas da empresa."

        texto_beneficio = (
            "A proporção dos benefícios "
            "será mantida, conforme sua "
            "escolha inicial. Caso queira "
            "realizar uma nova distribuição, "
            "aguarde a janela de janeiro."
        )

        # =============================
        # POSIÇÕES
        # =============================

        if beneficio:

            x_texto = 95

            y = 60

        else:

            x_texto = 80

            y = 90

        # =============================
        # NOME
        # =============================

        draw.text(
            (x_texto, y),
            f"{nome},",
            fill=COR,
            font=fonte_nome
        )

        y += 75

        # =============================
        # INTRODUÇÃO
        # =============================

        linhas_intro = quebrar_linhas(
            draw,
            texto_intro,
            fonte_texto,
            LARGURA_TEXTO
        )

        for linha in linhas_intro:

            draw.text(
                (x_texto, y),
                linha,
                fill=COR,
                font=fonte_texto
            )

            y += 30

        y += 10

        # =============================
        # TEXTO VARIÁVEL
        # =============================

        linhas_variavel = quebrar_linhas(
            draw,
            texto_variavel,
            fonte_texto,
            LARGURA_TEXTO
        )

        for linha in linhas_variavel:

            draw.text(
                (x_texto, y),
                linha,
                fill=COR,
                font=fonte_texto
            )

            y += 35


        # ==========
        # GERENTE
        # ==========
        if texto_gerente:
            y += 10

            linhas_gerente = quebrar_linhas(
                draw,
                texto_gerente,
                fonte_texto,
                LARGURA_TEXTO
            )

            for linha in linhas_gerente:
                draw.text(
                    (x_texto, y),
                    linha,
                    fill=COR,
                    font=fonte_texto
                )

                y += 30


        # =============================
        # BENEFÍCIO
        # =============================

        if beneficio:

            y += 10

            linhas_beneficio = quebrar_linhas(
                draw,
                texto_beneficio,
                fonte_texto,
                LARGURA_TEXTO2
            )

            for linha in linhas_beneficio:

                draw.text(
                    (x_texto, y),
                    linha,
                    fill=COR,
                    font=fonte_texto
                )

                y += 30

        # =============================
        # SALVAR
        # =============================

        nome_arquivo = f"{nome}.png"

        caminho_saida = os.path.join(
            PASTA_SAIDA,
            nome_arquivo
        )

        imagem.save(caminho_saida)
        imagem.close()

    # =================================
    # FINALIZADO
    # =================================
    root.update_idletasks()
    
    messagebox.showinfo(
        "Concluído",
        "Cartas criadas com sucesso!"
    )

